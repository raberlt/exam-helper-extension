{
    "manifest_version": 3,
    "name": "Exam Helper",
    "version": "3.1",
    "description": "Copy câu hỏi và tự động điền đáp án",
    "permissions": [
      "activeTab",
      "scripting",
      "clipboardRead"
    ],
    "host_permissions": ["<all_urls>"],
    "web_accessible_resources": [
      {
        "resources": ["prompts/*"],
        "matches": ["<all_urls>"]
      }
    ],
    "action": {
      "default_popup": "popup.html"
    }
  }