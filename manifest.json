{
    "manifest_version": 3,
    "name": "Exam Helper",
    "version": "2.1",
    "description": "Copy câu hỏi và tự động điền đáp án",
    "permissions": [
      "activeTab",
      "scripting",
      "clipboardRead"
    ],
    "host_permissions": ["<all_urls>"],
    "action": {
      "default_popup": "popup.html"
    }
  }